{
  "name": "@payloadtwist/ui-sandbox",
  "version": "0.1.0",
  "description": "Render Payload CMS UI components outside the admin panel. Preview shell for PayloadTwist.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css": {
      "import": "./dist/styles/shell.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@payloadcms/translations": ">=3.0.0",
    "@payloadcms/ui": ">=3.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@payloadcms/translations": "^3.78.0",
    "@payloadcms/ui": "^3.78.0",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
