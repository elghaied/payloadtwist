{
  "name": "@payloadtwist/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "typecheck": "tsc --noEmit",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "seed": "pnpx tsx seed/seed.ts",
    "extract-payload-theme": "pnpx tsx src/scripts/extract-payload-theme.ts && pnpx tsx src/scripts/analyze-scale-impact.ts",
    "analyze-scale-impact": "pnpx tsx src/scripts/analyze-scale-impact.ts",
    "fetch-google-fonts": "tsx scripts/fetch-google-fonts.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/translations": "3.78.0",
    "@payloadcms/ui": "3.78.0",
    "@payloadtwist/ui-sandbox": "workspace:^",
    "@tailwindcss/postcss": "^4.2.1",
    "better-auth": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.8.1",
    "libsql": "0.4.7",
    "lucide-react": "^0.575.0",
    "next": "15.4.11",
    "next-themes": "^0.4.6",
    "payload": "3.78.0",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-resizable-panels": "^4.7.0",
    "sharp": "0.34.2",
    "simple-icons": "^16.10.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "jsdom": "28.0.0",
    "shadcn": "^3.8.5",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  }
}
