# ── Required ──────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/payloadtwist_auth
BETTER_AUTH_SECRET=generate-a-random-string-minimum-32-characters
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: OAuth providers ─────────────────────────────
# Leave blank to disable OAuth login; email/password still works.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Turnstile CAPTCHA keys (optional, but recommended for production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=